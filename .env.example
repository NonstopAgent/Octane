# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# GitHub (server-only — read integrations + coding workbench PR workflow)
# Scopes: repo contents (read/write for docs PRs only via /api/coding/*)
GITHUB_TOKEN=github_pat_...

# Vercel (optional, read-only deployments)
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# App URL (optional, for absolute links in server routes)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Outbound critical alerts (optional, server-only — Slack-compatible webhook POST)
WEBHOOK_ALERT_URL=
